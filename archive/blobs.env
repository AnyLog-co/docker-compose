#--- Blob Data Store ---
# Store blobs in external storage (mongo, akave, s3, minio, etc.)
BLOBS_STORAGE=false

# Storage type
BLOB_STORAGE_TYPE=mongo

# Reuse repeating blobs - based on file hash value
BLOBS_REUSE=true
# Compress blobs when stored
BLOBS_COMPRESS=true

# Store blobs to local file system folder (true/false/"" to use default behavior)
BLOBS_FOLDER=""

# URL or IP address to access blob storage
BLOB_STORAGE_IP=127.0.0.1
# Port for connecting to blob storage
BLOB_STORAGE_PORT=27071

#--- Blob DBMS Credentials ---
# Credentials for blob database (ex. MongoDB)
BLOB_STORAGE_USER=admin
BLOB_STORAGE_PASSWORD=passwd

#--- Remote Blob Storage (S3 / Akave / MinIO / etc.) ---
# Bucket to store blobs in
BUCKET_GROUP=""
BUCKET_ID=""

# Bucket credentials
BUCKET_ACCESS_KEY=""
BUCKET_SECRETE_KEY=""

# Bucket region
BUCKET_REGION=""
