#--- General ---
# AnyLog License Key
LICENSE_KEY=""
# Information regarding which AnyLog node configurations to enable. By default, even if everything is disabled, AnyLog starts TCP and REST connection protocols
NODE_TYPE=operator
# Name of the AnyLog instance
NODE_NAME=anylog-operator2
# Owner of the AnyLog instance
COMPANY_NAME=AnyLog Co.

#--- Networking ---
# Port address used by AnyLog's TCP protocol to communicate with other nodes in the network
ANYLOG_SERVER_PORT=32148
# Port address used by AnyLog's REST protocol
ANYLOG_REST_PORT=32149
# Port value to be used as an MQTT broker, or some other third-party broker
ANYLOG_BROKER_PORT=""
# A bool value that determines if to bind to a specific IP and Port (a false value binds to all IPs)
TCP_BIND=true
# A bool value that determines if to bind to a specific IP and Port (a false value binds to all IPs)
REST_BIND=false
# A bool value that determines if to bind to a specific IP and Port (a false value binds to all IPs)
BROKER_BIND=false

#--- Database ---
# Physical database type
DB_TYPE=sqlite
# Username for SQL database connection
DB_USER=""
# Password correlated to database user
DB_PASSWD=""
# Database IP address
DB_IP=""
# Database port number
DB_PORT=5432
# Whether to set autocommit data
AUTOCOMMIT=true

#--- Blob Data Store --
# store blobs in storage that's not local file system
BLOBS_STORAGE=false

# Storage type (mongo, akave, s3 , etc)
BLOB_STORAGE_TYPE=mongo

# Reuse repeating blobs - based on file hash value
BLOBS_REUSE=true
# Compress Blobs
BLOBS_COMPRESS=true

# by default we're storing blobs to local files, so disable that option - either by user or us
# - user can force disable by setting folder as False
# - user can force enable by setting  folder as True
BLOBS_FOLDER=""

# URL or IP address to access blob storage
BLOB_STORAGE_IP=127.0.0.1

# Port for connecting to blob DBMS storage
BLOB_STORAGE_PORT=27071

#--- Blobs DBMS ---
# Database object data storage (ex. MongoDB) credentials
BLOB_STORAGE_USER=admin
BLOB_STORAGE_PASSWORD=passwd

#--- Blobs Remote Storage ---
# Bucket to store blobs in
BUCKET_GROUP=""
BUCKET_ID=""

# Bucket credentials
BUCKET_ACCESS_KEY=""
BUCKET_SECRETE_KEY=""

# Bucket Region
BUCKET_REGION=""

# Store blobs in database
BLOBS_DBMS=true
# Whether (re)store a blob if already exists
BLOBS_REUSE=true
BLOBS_FOLDER=false

#--- Blockchain ---
# TCP connection information for Master Node
LEDGER_CONN=127.0.0.1:32048
# How often to sync from blockchain
BLOCKCHAIN_SYNC=60 second
# Source of where the data is coming from
BLOCKCHAIN_SOURCE=master
# Where will the copy of the blockchain be stored
BLOCKCHAIN_DESTINATION=file

#--- Operator ---
# Owner of the cluster
CLUSTER_NAME=anylog-cluster2
# Logical database name
DEFAULT_DBMS=mydb

#--- Aggregation --
# Specific aggregation policy - use python3 script to create aggregation policy
# https://github.com/AnyLog-co/deployment-scripts/tree/os-dev/aggregations
AGGREGATION_POLICY=""

# Enable generic aggregation
ENABLE_AGGREGATIONS=false

# Aggregation logical database
AGGREGATIONS_DBMSmydb
# Aggregation table  - `*` is set to all tables
set AGGREGATIONS_TABLE=* then set aggregations_table = $AGGREGATIONS_TABLE
# number of aggregation intervals
AGGREGATIONS_INTERVALS=10
# aggregation time period per aggregation
AGGREGATIONS_TIME="1 minute"
# aggregation timestamp column
AGGREGATION_TIME_COLUMN=timestamp
# aggregation value column
AGGREGATION_VALUE_COLUMN=value

# Ingest raw (non-aggregated) data
INGEST_RAW_DATA=true
# Ingest aggregated data
INGEST_AGGREGATIONS=false

# Enable value encoding (true / false)
ENABLE_ENCODING=false

# Encoding tolerance (numeric)
ENCODING_TOLERANCE=""

# set encoding type:
# "" - do not specify encoding type
# - bounds - all entries in the time interval are replaced with a single entry representing:
# - arle - Approximated Run-Length Encoding, the entries in the time interval are represented in a sequence of entries. Each entry includes:
ENCODING_TYPE=""


#--- Monitoring ---
# Whether to monitor the node or not
MONITOR_NODES=true
# Store monitoring in Operator node(s)
STORE_MONITORING=false
# get / store syslog data
SYSLOG_MONITORING=false
# get / store docker insight
DOCKER_MONITORING=false
# destination to store monitoring
NODE_STORAGE_DEST=""

