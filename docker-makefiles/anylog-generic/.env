# --- Deployment Configs ---
# -> prod: run AnyLog instance
# -> bash: run shell interface with AnyLog installed and params set
INIT_TYPE=prod

# AnyLog image
IMAGE=anylogco/anylog-network

# Github repo to use for configuring / deploying node
DEPLOYMENTS_REPO="https://github.com/AnyLog-co/deployment-scripts"
# Branch associated with git repo
DEPLOYMENTS_BRANCH="os-dev"

# --- Remote-GUI ---
# REACT application IP
REACT_APP_API_IP=""
# Remote GUI Frontend Port
REMOTE_GUI_FE=31800
# Remote GUI Backend Port
REMOTE_GUI_BE=8080
# Grafana PATH to reference for Grafana connection
GRAFANA_URL=""

