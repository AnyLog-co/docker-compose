# AnyLog init type
# -> prod: run AnyLog instance
# -> bash: run shell interface with AnyLog installed and params set
INIT_TYPE=prod

# AnyLog image
IMAGE=anylogco/anylog-network


# params for Remote-CLI
REMOTE_GUI_NIC=eth0
REMOTE_GUI_IP=""
GRAFANA_URL=""

DEPLOYMENTS_REPO="https://github.com/AnyLog-co/deployment-scripts"
DEPLOYMENTS_BRANCH="os-dev"
