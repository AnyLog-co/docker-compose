#--- Directories ---
# AnyLog Root Path
ANYLOG_PATH=/app
# !local_scripts: ${ANYLOG_HOME}/deployment-scripts/scripts
LOCAL_SCRIPTS=/app/deployment-scripts
# !test_dir: ${ANYLOG_HOME}/deployment-scripts/test
TEST_DIR=/app/deployment-scripts/test

#--- General ---
# Coordinates of the machine - used by Grafana to map the network
LOCATION=48.7758,9.1829
# Country where machine is located
COUNTRY=Germany
# State where machine is located
STATE=Baden-Wurttemberg
# City where machine is located
CITY=Stuttgart

#--- Networking ---
# Whether to enable DNS resolution
ENABLE_DNS=false
# External DNS resolution
EXTERNAL_DNS=""
# local DNS domain to append to hostname (ex. example.com)
DNS_DOMAIN=""
# Full path for machine's (local) DNS
DNS=""

#--------------------------------------------------
# Blob Storage Behavior
#--------------------------------------------------
# Reuse identical blobs using file hash
BLOBS_REUSE=true
# Compress blobs before storage
BLOBS_COMPRESS=true

#--------------------------------------------------
# Local Filesystem Blob Storage
#--------------------------------------------------
# Folder for storing blobs locally
# Leave empty to use default application path
BLOBS_FOLDER=""

#--------------------------------------------------
# Object Storage (S3 / Akave / MinIO)
#--------------------------------------------------

# Logical bucket grouping
BUCKET_GROUP=""

# Bucket identifier
BUCKET_ID=""

# Access credentials
BUCKET_ACCESS_KEY=""
BUCKET_SECRETE_KEY=""

# Cloud region
BUCKET_REGION=""

#--- MQTT ---
# Whether to enable the default MQTT process
ENABLE_MQTT=false

# IP address of MQTT broker
MQTT_BROKER=172.104.228.251
# Port associated with MQTT broker
MQTT_PORT=1883
# User associated with MQTT broker
MQTT_USER=anyloguser
# Password associated with MQTT user
MQTT_PASSWD=mqtt4AnyLog!
# Whether to enable MQTT logging process
MQTT_LOG=false

# Topic to get data for
MSG_TOPIC=anylog-demo
# Logical database name
MSG_DBMS=mydb
# Table where to store data
MSG_TABLE=bring [table]
# Timestamp column name
MSG_TIMESTAMP_COLUMN=bring [timestamp]
# Value column name
MSG_VALUE_COLUMN=bring [value]
# Column value type
MSG_VALUE_COLUMN_TYPE=float

#----- OPC-UA ---
# Whether or not to enable to OPC-UA service
ENABLE_OPCUA=false
# OPC-UA URL address (ex. opcua.tcp:;//127.0.0.1:4840)
OPCUA_URL=""
# Node information the root is located in (ex. ns=2;s=DataSet)
OPCUA_NODE=""
# How often to pull data from OPC-UA
OPCUA_FREQUENCY=5

#--- Advanced Settings ---
# hide blockchain policy - supports all node types except cluster / operator
IS_HIDDEN = false
# Whether to automatically run a local (or personalized) script at the end of the process
DEPLOY_LOCAL_SCRIPT=false
# Compress JSON and SQL file(s) backup
COMPRESS_FILE=true
# Number of parallel queries
QUERY_POOL=6
# When data comes in write to database immediately, as opposed to waiting for a full buffer
WRITE_IMMEDIATE=true
# If buffer is not full, how long to wait until pushing data through
THRESHOLD_TIME=60 seconds
# Buffer size to reach, at which point data is pushed through
THRESHOLD_VOLUME=10KB
# Enable remote CLI
REMOTE_CLI=true
